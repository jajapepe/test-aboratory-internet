{
  "name": "developer-landing",
  "version": "1.0.0",
  "description": "Developer portfolio landing page with contact form",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:backend": "nodemon server/index.js",
    "dev:frontend": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "predeploy": "npm run build",
    "deploy": "gh-pages -d dist",
    "start": "node server/index.js"
  },
  "keywords": [
    "portfolio",
    "landing",
    "express"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.1.5",
    "express-validator": "^7.2.0",
    "helmet": "^7.1.0",
    "nodemailer": "^6.9.14"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "gh-pages": "^6.3.0",
    "nodemon": "^3.1.4",
    "sass": "^1.77.8",
    "vite": "^5.4.2"
  }
}
